<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="scanly-index.db" />
        <exclude domain="database" path="scanly-index.db-wal" />
        <exclude domain="database" path="scanly-index.db-shm" />
        <exclude domain="file" path="datastore/scanly_library_access.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="scanly-index.db" />
        <exclude domain="database" path="scanly-index.db-wal" />
        <exclude domain="database" path="scanly-index.db-shm" />
        <exclude domain="file" path="datastore/scanly_library_access.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
